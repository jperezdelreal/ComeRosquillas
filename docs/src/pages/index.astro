---
import GameLayout from '../layouts/GameLayout.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<GameLayout title="Homer's Donut Quest">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FFD700]/10 via-transparent to-[#FF6347]/10"></div>
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-[#FFD700]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-96 h-96 bg-[#FF8C00]/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-40 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#FFD700]/30 bg-[#FFD700]/10 text-sm text-[#FFE44D] mb-8">
        <span>A First Frame Studios Game</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">
        🍩 ComeRosquillas
      </h1>
      <p class="text-2xl md:text-3xl text-[#FFE44D] font-semibold mb-4">
        Homer's Donut Quest
      </p>
      <p class="text-lg md:text-xl text-[#9890b0] max-w-2xl mx-auto mb-10 leading-relaxed">
        A Simpsons-themed Pac-Man arcade game. Guide Homer through the streets of Springfield, collect donuts, grab Duff power-ups, and outsmart Burns, Sideshow Bob, Nelson & Snake!
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}play/`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#FFD700] hover:bg-[#FF8C00] text-[#1a0a2e] rounded-lg font-bold text-lg transition-colors shadow-lg shadow-[#FFD700]/20">
          🎮 Play Now
        </a>
        <a href="https://github.com/jperezdelreal/ComeRosquillas" target="_blank"
          class="inline-flex items-center gap-2 px-6 py-4 border border-white/20 hover:border-white/40 text-white rounded-lg font-medium transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View Source
        </a>
      </div>
    </div>
  </section>

  <!-- Game Embed Section -->
  <section class="fade-on-scroll max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Try It Out</h2>
      <p class="text-[#9890b0] max-w-xl mx-auto">Play right here in your browser — no downloads needed.</p>
    </div>
    <div class="relative rounded-2xl border border-[#FFD700]/30 bg-[#1a0a2e] overflow-hidden shadow-2xl shadow-[#FFD700]/10">
      <iframe
        id="home-game-frame"
        src={`${base}game/`}
        class="w-full aspect-[4/3] md:aspect-[16/10]"
        title="ComeRosquillas — Homer's Donut Quest"
        allow="autoplay; keyboard-map"
        loading="lazy"
      ></iframe>
    </div>
    <p class="text-center text-sm text-[#9890b0] mt-4">
      Click the game and use <span class="text-[#FFD700]">← ↑ ↓ →</span> to move · <span class="text-[#FFD700]">P</span> to pause · <span class="text-[#FFD700]">M</span> for music · <span class="text-[#FFD700]">ENTER</span> to start
    </p>
  </section>

  <!-- Features Section -->
  <section class="fade-on-scroll max-w-6xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Packed with Features</h2>
      <p class="text-[#9890b0] max-w-xl mx-auto">20+ features shipped. Not your average Pac-Man clone.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🍩</div>
        <h3 class="text-white font-semibold text-lg mb-2">Collect Donuts</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Navigate Homer through Springfield, gobbling donuts in every corner. 6 themed maze locations — from Moe's Tavern to the Nuclear Plant.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">👻</div>
        <h3 class="text-white font-semibold text-lg mb-2">4 Ghost Personalities</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Sr. Burns chases, Bob Patiño ambushes, Nelson patrols, Snake roams. Each villain uses BFS pathfinding with unique AI behaviors.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🎮</div>
        <h3 class="text-white font-semibold text-lg mb-2">Boss Fights</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Every 5 levels, face a boss ghost — Fat Tony, Krusty, Sideshow Bob, or Mr. Burns Mega — each with special mechanics.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">⚡</div>
        <h3 class="text-white font-semibold text-lg mb-2">5 Power-ups</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Duff Beer, Donut Box, Chili Pepper, Burns Token, Lard Lad — each with unique effects to turn the tide.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🏆</div>
        <h3 class="text-white font-semibold text-lg mb-2">23 Achievements</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Unlock achievements with animated notifications. Track your stats on the full dashboard and compete on the leaderboard.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🎲</div>
        <h3 class="text-white font-semibold text-lg mb-2">10 Mini-Events</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Double Trouble, Speed Run, Darkness, Ghost Frenzy — random events keep every playthrough unpredictable and exciting.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🌍</div>
        <h3 class="text-white font-semibold text-lg mb-2">5 Languages</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Play in English, Spanish, French, German, or Portuguese (BR). Full UI localization with instant language switching.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">♿</div>
        <h3 class="text-white font-semibold text-lg mb-2">Fully Accessible</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">Colorblind modes (Protanopia, Deuteranopia, Tritanopia), screen reader announcements, and reduced motion support.</p>
      </div>
      <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-[#FFD700]/30 transition-all duration-300">
        <div class="text-3xl mb-4">🎵</div>
        <h3 class="text-white font-semibold text-lg mb-2">Procedural Audio</h3>
        <p class="text-sm text-[#9890b0] leading-relaxed">All music and sound effects synthesized at runtime via Web Audio API. Zero audio files — pure oscillator magic.</p>
      </div>
    </div>
  </section>

  <!-- Tech & Studio Section -->
  <section class="fade-on-scroll max-w-4xl mx-auto px-6 py-20 text-center">
    <div class="p-10 rounded-2xl border border-[#FFD700]/20 bg-gradient-to-br from-[#FFD700]/5 to-transparent">
      <h2 class="text-3xl font-bold text-white mb-4">Built by AI Agents 🤖</h2>
      <p class="text-[#9890b0] max-w-lg mx-auto mb-6">
        ComeRosquillas was developed by the AI agent squad at First Frame Studios — 15 specialized agents collaborating to ship real, playable games.
      </p>
      <a href="https://jperezdelreal.github.io/FirstFrameStudios/" target="_blank"
        class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/15 text-white rounded-lg font-medium transition-colors">
        Visit First Frame Studios →
      </a>
    </div>
  </section>
</GameLayout>

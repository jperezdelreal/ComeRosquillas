---
import GameLayout from '../layouts/GameLayout.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<GameLayout title="Play" fullscreen={true}>
  <div class="flex flex-col items-center justify-center flex-1 p-4">
    <div class="w-full max-w-4xl">
      <div class="flex items-center justify-between mb-4 px-2">
        <a href={base} class="text-sm text-[#9890b0] hover:text-[#FFE44D] transition-colors flex items-center gap-1">
          ← Back to Home
        </a>
        <span class="text-sm text-[#FFD700] font-medium">🍩 ComeRosquillas</span>
      </div>
      <div class="relative rounded-xl border border-[#FFD700]/30 bg-[#1a0a2e] overflow-hidden shadow-2xl shadow-[#FFD700]/10">
        <iframe
          src={`${base}game/`}
          class="w-full"
          style="aspect-ratio: 672 / 820; max-height: calc(100vh - 120px);"
          title="ComeRosquillas — Homer's Donut Quest"
          allow="autoplay"
        ></iframe>
      </div>
      <p class="text-center text-xs text-[#9890b0] mt-3">
        <span class="text-[#FFD700]">← ↑ ↓ →</span> Move · <span class="text-[#FFD700]">P</span> Pause · <span class="text-[#FFD700]">M</span> Music · <span class="text-[#FFD700]">ENTER</span> Start
      </p>
    </div>
  </div>
</GameLayout>

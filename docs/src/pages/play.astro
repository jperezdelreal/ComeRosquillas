---
import GameLayout from '../layouts/GameLayout.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<GameLayout title="Play" fullscreen={true}>
  <div class="game-play-wrapper flex flex-col items-center justify-center flex-1 p-4">
    <div class="w-full max-w-4xl">
      <div class="game-play-header flex items-center justify-between mb-4 px-2">
        <a href={base} class="text-sm text-[#9890b0] hover:text-[#FFE44D] transition-colors flex items-center gap-1">
          ← Back to Home
        </a>
        <span class="text-sm text-[#FFD700] font-medium">🍩 ComeRosquillas</span>
      </div>
      <div class="relative rounded-xl border border-[#FFD700]/30 bg-[#1a0a2e] overflow-hidden shadow-2xl shadow-[#FFD700]/10 game-play-frame-wrap">
        <iframe
          id="game-frame"
          src={`${base}game/`}
          class="w-full"
          style="aspect-ratio: 672 / 820; max-height: calc(100vh - 120px);"
          title="ComeRosquillas — Homer's Donut Quest"
          allow="autoplay; keyboard-map"
        ></iframe>
      </div>
      <p class="game-play-hints text-center text-xs text-[#9890b0] mt-3">
        <span class="text-[#FFD700]">← ↑ ↓ →</span> Move · <span class="text-[#FFD700]">P</span> Pause · <span class="text-[#FFD700]">M</span> Music · <span class="text-[#FFD700]">ENTER</span> Start
      </p>
    </div>
  </div>

  <style>
    /* Mobile touch portrait: strip all chrome, let iframe fill screen */
    @media (hover: none) and (pointer: coarse) and (orientation: portrait) {
      .game-play-wrapper {
        padding: 0 !important;
        justify-content: flex-start !important;
      }
      .game-play-header {
        display: none !important;
      }
      .game-play-hints {
        display: none !important;
      }
      .game-play-frame-wrap {
        border-radius: 0 !important;
        border: none !important;
        box-shadow: none !important;
      }
      #game-frame {
        aspect-ratio: auto !important;
        max-height: none !important;
        height: 100vh !important;
        height: 100dvh !important;
      }
    }
  </style>
  <script>
    // Auto-focus iframe so keyboard events reach the game
    const frame = document.getElementById('game-frame');
    if (frame) {
      frame.addEventListener('load', () => frame.focus());
      frame.addEventListener('click', () => frame.focus());
      setTimeout(() => frame.focus(), 500);
    }
  </script>
</GameLayout>
